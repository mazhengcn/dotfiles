# SSH — only track the .gitkeep
ssh/config.d/*
!ssh/config.d/.gitkeep

# Config state files (generated, not tracked)
config/tmux/plugins
config/nvim/lazy-lock.json
config/nvim/lazyvim.json
config/zed/.tmp*
config/zed/embeddings
config/zed/prompts

# Claude Code — local overrides
.claude/*.local.json

# Secrets & local config
.zshrc.local
.python-version

# OS junk
.DS_Store
*.sw[po]
*.o

# Editor temp files
\#*#
*#
.#*
.*~
*~
Session.vim
.netrwhist

# Tags
tags
TAGS

# Misc
*.dSYM
*.log
.svn
node_modules
