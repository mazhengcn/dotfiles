{
  "vim_mode": true,
  // Editor
  "autosave": "on_focus_change",
  "format_on_save": "on",
  "soft_wrap": "editor_width",
  "inlay_hints": {
    "enabled": true,
  },
  "diagnostics": {
    "inline": {
      "enabled": true,
    },
  },
  "toolbar": {
    "breadcrumbs": false,
    "quick_actions": false,
  },
  // Theme
  "theme": "Catppuccin Espresso (Blur)",
  "icon_theme": "Catppuccin Mocha",
  // Typography
  "buffer_font_family": "Maple Mono NF CN",
  "buffer_font_size": 18,
  "buffer_line_height": {
    "custom": 1.8,
  },
  "buffer_font_features": {
    "calt": true,
  },
  "ui_font_family": "Maple Mono NF CN",
  "ui_font_features": {
    "calt": true,
  },
  "agent_buffer_font_size": 18,
  // Extensions
  "auto_install_extensions": {
    "catppuccin-blur": true,
    "catppuccin-icons": true,
  },
}
